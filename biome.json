{
	"$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
	"vcs": { "enabled": false, "clientKind": "git", "useIgnoreFile": false },
	"files": { "includes": ["**", "!**/dist", "!**/node_modules"] },
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"includes": ["**"],
		"attributePosition": "auto",
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 200,
		"lineEnding": "lf"
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"style": { "useConst": "off", "useImportType": "off" },
			"suspicious": { "noExplicitAny": "off", "noShadowRestrictedNames": "off" },
			"complexity": { "noBannedTypes": "off" }
		}
	},
	"javascript": { "formatter": { "enabled": true, "quoteStyle": "double" }, "parser": { "unsafeParameterDecoratorsEnabled": true } },
	"json": { "formatter": { "enabled": true, "indentStyle": "tab" } },
	"overrides": [{ "includes": ["**/*.js", "**/*.ts", "**/*.svelte", "**/*.astro", "**/*.vue"], "linter": { "rules": { "style": { "useConst": "off", "useImportType": "off" } } } }]
}
